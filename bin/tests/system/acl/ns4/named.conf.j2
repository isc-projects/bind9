options {
	query-source address 10.53.0.4;
	notify-source 10.53.0.4;
	transfer-source 10.53.0.4;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.4; };
	listen-on-v6 { none; };
	recursion no;
	notify no;
	allow-new-zones yes;
	allow-transfer { none; };
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

zone "existing" {
	type primary;
	file "existing.db";
};

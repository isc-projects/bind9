options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	recursion no;
	notify no;
	allow-new-zones yes;
	allow-transfer { none; };
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

template "allow-xfr" {
	type primary;
	allow-transfer { any; };
};

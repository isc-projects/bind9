options {
	query-source address 10.53.0.1;
	notify-source 10.53.0.1;
	transfer-source 10.53.0.1;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	listen-on-v6 { none; };
	recursion no;
	dnssec-validation no;
	notify yes;
	statistics-file "named.stats";
};

{% include "_common/controls.conf.j2" %}

zone "." {
	type primary;
	file "root.db";
};

options {
	query-source address 10.53.0.8;
	notify-source 10.53.0.8;
	transfer-source 10.53.0.8;
	port @PORT@;
	pid-file "named.pid";
	session-keyfile "session.key";
	listen-on { 10.53.0.8; };
	listen-on-v6 { none; };
	recursion no;
	notify yes;
	minimal-responses no;
	dnssec-validation no;
	tkey-gssapi-keytab "dns-other-than-KRB5_KTNAME.keytab";
};

{% include "_common/controls.conf.j2" %}

zone "in-addr.arpa" {
	type primary;
	file "in-addr.db";
	update-policy {	grant EXAMPLE.COM krb5-subdomain . PTR; };
};

zone "example.com" {
	type primary;
	file "example.com.db";
	update-policy {
		grant EXAMPLE.COM krb5-selfsub . ANY;
		grant EXAMPLE.COM krb5-subdomain _tcp.example.com SRV;
	};
};

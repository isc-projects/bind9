options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	recursion yes;
	dnssec-validation no;
	check-names response fail;
	notify yes;
};

{% include "_common/controls.conf.j2" %}

zone "." {
	type hint;
	file "root.hints";
};

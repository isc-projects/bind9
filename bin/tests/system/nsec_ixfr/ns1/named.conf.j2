{% include "_common/controls.conf.j2" %}

options {
	query-source address 10.53.0.1;
	notify-source 10.53.0.1;
	transfer-source 10.53.0.1;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	notify yes;
	dnssec-validation no;
};

zone "example" {
	type primary;
	file "example.db";
	also-notify { 10.53.0.2 port @PORT@; };
	ixfr-from-differences yes;
};

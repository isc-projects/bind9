// NS2

options {
	query-source address 10.53.0.2;
	notify-source 10.53.0.2;
	transfer-source 10.53.0.2;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.2; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	notify yes;
        notify-delay 1;
	dnssec-validation no;
	minimal-responses no;
};

{% include "_common/controls.conf.j2" %}

zone "example" {
	type primary;
	file "example.db.signed";
	allow-update { any; };
};

zone "corp" {
	type primary;
	file "corp.db";
};

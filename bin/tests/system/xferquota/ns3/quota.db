$TTL 300
@	IN SOA	ns1.quota. hostmaster.quota. (
			1		; serial
			3600		; refresh
			1800		; retry
			604800		; expire
			600		; minimum
			)
	IN NS	ns1.quota.
ns1	IN A	10.53.0.3
www	IN A	10.0.0.1

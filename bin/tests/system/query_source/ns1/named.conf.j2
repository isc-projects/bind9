{% include "_common/controls.conf.j2" %}

options {
	port @PORT@;
	pid-file "named.pid";
	listen-on-v6 { fd92:7065:b8e:ffff::1; };
	listen-on { 10.53.0.1; };
	recursion no;
	dnssec-validation no;

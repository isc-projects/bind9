// NS1

acl allowed {
	! 10.53.0.5;
	any;
};

options {
	query-source address 10.53.0.1;
	notify-source 10.53.0.1;
	transfer-source 10.53.0.1;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	listen-on-v6 { none; };
	recursion no;
	notify no;
	dnssec-validation no;
	allow-query { allowed; };
};


{% include "_common/controls.conf.j2" %}

zone "." {
	type primary;
	file "root.db.signed";
};

zone "tld" {
	type primary;
	file "tld.db.signed";
};

zone "sub.tld" {
	type primary;
	file "sub.tld.db.signed";
};

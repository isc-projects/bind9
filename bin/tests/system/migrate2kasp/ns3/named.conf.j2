// NS3

include "kasp.conf";

options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

/* These are zones that migrate to dnssec-policy. */
zone "migrate.kasp" {
	type primary;
	file "migrate.kasp.db";
	dnssec-policy "migrate";
	inline-signing no;
	allow-update { any; };
};

zone "csk.kasp" {
	type primary;
	file "csk.kasp.db";
	dnssec-policy "default";
	inline-signing no;
	allow-update { any; };
};


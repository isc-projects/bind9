$TTL 300
example4.tld.		IN SOA	owner.dnshoster.tld. ns.dnshoster.tld. (
				2010   	; serial
				600         	; refresh
				600         	; retry
				1200    	; expire
				600       	; minimum
				)

example4.tld.		NS	ns.example4.tld.
ns.example4.tld. 	A	10.53.0.3
sub.example4.tld.	NS	ns1.dnshoster.tld.
sub.example4.tld.	NS	ns2.dnshoster.tld.

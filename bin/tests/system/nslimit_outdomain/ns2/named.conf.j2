options {
	query-source address 10.53.0.2;
	notify-source 10.53.0.2;
	transfer-source 10.53.0.2;
	port @PORT@;
	pid-file "named.pid";
	listen-on {
		10.53.0.2;
		10.53.0.5;
		10.53.0.6;
		10.53.0.7;
		10.53.1.1;
		10.53.1.2;
		10.53.2.2;
	};
	recursion no;
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

zone "tld." {
	type primary;
	file "tld.db";
};

zone "dnshoster.tld." {
	type primary;
	file "dnshoster.tld.db";
};

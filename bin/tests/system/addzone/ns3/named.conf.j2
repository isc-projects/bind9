{% include "_common/controls.conf.j2" %}

options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	allow-query { any; };
	allow-transfer { any; };
	recursion no;
	allow-new-zones yes;
	dnssec-validation no;
};

zone "." {
	type primary;
	file "redirect.db";
};

remote-servers "test" {
	10.53.0.99;
};

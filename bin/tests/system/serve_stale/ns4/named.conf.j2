{% include "_common/controls.conf.j2" %}

options {
	query-source address 10.53.0.4;
	notify-source 10.53.0.4;
	transfer-source 10.53.0.4;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.4; };
	listen-on-v6 { none; };
	recursion yes;
	dnssec-validation no;
	dump-file "named_dump.db";
	stale-answer-enable no;
	stale-cache-enable yes;
};

zone "." {
	type secondary;
	primaries { 10.53.0.1; };
	file "root.bk";
};

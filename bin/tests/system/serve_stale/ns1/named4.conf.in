key rndc_key {
	secret "1234abcd8765";
	algorithm @DEFAULT_HMAC@;
};

controls {
	inet 10.53.0.1 port @CONTROLPORT@ allow { any; } keys { rndc_key; };
};

options {
	query-source address 10.53.0.1;
	notify-source 10.53.0.1;
	transfer-source 10.53.0.1;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion yes;
	dnssec-validation no;
	max-stale-ttl 20;
	stale-answer-ttl 3;
	stale-answer-enable yes;
	stale-cache-enable yes;
	stale-refresh-time 0;
	servfail-ttl 0;
};

zone "." {
	type primary;
	file "root.db";
};

zone "stale.test" {
	type primary;
	file "stale.test.db";
	allow-update { any; };
};

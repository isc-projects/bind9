// NS6

{% include "_common/controls.conf.j2" %}

options {
	query-source address 10.53.0.6;
	notify-source 10.53.0.6;
	transfer-source 10.53.0.6;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.6; };
	listen-on-v6 { none; };
	recursion yes;
	notify yes;
	notify-delay 0;
	dnssec-validation yes;
};

zone "." {
	type hint;
	file "../../_common/root.hint";
};

include "trusted.conf";

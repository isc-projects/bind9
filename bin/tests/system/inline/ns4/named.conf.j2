// NS4

options {
	query-source address 10.53.0.4;
	notify-source 10.53.0.4;
	transfer-source 10.53.0.4;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.4; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	notify yes;
	notify-delay 0;
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

zone "noixfr" {
	type primary;
	file "noixfr.db";
	allow-update { any; };
};

options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	recursion no;
	dnssec-validation no;
};

zone "dnshoster.tld." {
	type primary;
	file "dnshoster.tld.db";
};

zone "example.tld." {
	type primary;
	file "example.tld.db";
};


options {
	query-source address 10.53.0.2;
	notify-source 10.53.0.2;
	transfer-source 10.53.0.2;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.2; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	dnssec-validation yes;
};

zone truncated.selfsigned. {
	type primary;
	file "truncated.selfsigned.db.signed";
};

include "trusted.conf";

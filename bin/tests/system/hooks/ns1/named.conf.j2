options {
	query-source address 10.53.0.1;
	notify-source 10.53.0.1;
	transfer-source 10.53.0.1;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	recursion no;
	dnssec-validation no;
	notify yes;
	minimal-responses no;
};


plugin query "../driver/.libs/test-async.so";

{% include "_common/controls.conf.j2" %}

zone "example.com" {
	type primary;
	file "example.db";
};

// NS5

include "../kasp.conf";

options {
	query-source address 10.53.0.5;
	notify-source 10.53.0.5;
	transfer-source 10.53.0.5;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.5; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	key-directory ".";
	dnssec-validation no;
	notify-delay 0;
};

{% include "_common/controls.conf.j2" %}

zone "model2.secondary." {
	type primary;
	allow-update { any; };
	file "model2.secondary.db";
};

zone "." {
	type hint;
	file "../../_common/root.hint";
};

include "trusted.conf";

// NS2

options {
	query-source address 10.53.0.2;
	notify-source 10.53.0.2;
	transfer-source 10.53.0.2;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.2; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	allow-notify { 10.53.0.3; 10.53.0.4; };
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

zone "multisigner" {
	type primary;
	file "multisigner.db.signed";
};

zone "update-any" {
	type primary;
	file "update-any.db.signed";
};

zone "bad-dsync" {
	type primary;
	file "bad-dsync.db.signed";
};

zone "secondary" {
	type primary;
	file "secondary.db.signed";
};

zone "." {
	type hint;
	file "../../_common/root.hint";
};

include "trusted.conf";

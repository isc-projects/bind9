options {
	query-source address 10.53.0.1;
	notify-source 10.53.0.1;
	transfer-source 10.53.0.1;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	dnssec-validation no;
	notify no;
	rrset-order {
		name "cyclic.example" order cyclic;
		name "none.example" order none;
		type NS order random;
		order cyclic;
	};
};

{% include "_common/controls.conf.j2" %}

zone "." {
	type primary;
	file "root.db";
	notify explicit;
	also-notify { 10.53.0.2; };
};

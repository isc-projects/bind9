// NS3

options {
	query-source address @ns.ip@;
	notify-source @ns.ip@;
	transfer-source @ns.ip@;
	port @PORT@;
	pid-file "named.pid";
	listen-on { @ns.ip@; };
	listen-on-v6 { none; };

	key-directory "keys";

	minimal-any no;
	minimal-responses no;
	recursion no;

	dnssec-validation yes;
};


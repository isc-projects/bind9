{% include "_common/controls.conf.j2" %}

options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	recursion yes;
	dnssec-validation no;
	response-policy { zone "policy"; }
                nsip-wait-recurse no
                nsdname-wait-recurse no
		nsdname-enable yes;
};


zone "policy" { type primary; file "policy.db"; };

zone "example.tld" { type primary; file "example.db"; };

zone "." { type primary; file "root.db"; };

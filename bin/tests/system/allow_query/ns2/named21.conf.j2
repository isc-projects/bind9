options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.2; };
	listen-on-v6 { none; };
	recursion no;
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

view "internal" {

	zone "." {
		type hint;
		file "../../_common/root.hint";
	};

	zone "normal.example" {
		type primary;
		file "generic.db";
	};
};

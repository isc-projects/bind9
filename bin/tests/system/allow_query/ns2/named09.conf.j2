acl accept { 10.53.0.2; };

options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.2; };
	listen-on-v6 { none; };
	recursion no;
	allow-query {! accept; };
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

zone "." {
	type hint;
	file "../../_common/root.hint";
};

zone "normal.example" {
	type primary;
	file "generic.db";
};

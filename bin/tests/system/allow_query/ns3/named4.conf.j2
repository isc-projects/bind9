options {
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; 10.53.1.2; };
	listen-on-v6 { none; };
	recursion yes;
	allow-recursion { any; };
	allow-query-cache { any; };
	allow-recursion-on { 10.53.0.3; }; # allow-query-cache-on inherits
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

zone "." {
	type hint;
	file "../../_common/root.hint";
};

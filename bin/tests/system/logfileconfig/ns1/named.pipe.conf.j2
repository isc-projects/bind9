options {
	query-source address 10.53.0.1;
	notify-source 10.53.0.1;
	transfer-source 10.53.0.1;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	listen-on-v6 { none; };
	dnssec-validation no;
	recursion no;
	notify yes;
};

logging {
	channel default_log {
	  file "named_pipe";
	  print-time yes;
	};
	category default { default_log; default_debug; };
	category lame-servers { null; };
};


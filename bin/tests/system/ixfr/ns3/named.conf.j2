options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	allow-transfer { any; };
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	recursion no;
	notify yes;
	dnssec-validation no;
};

{% include "_common/controls.conf.j2" %}

view "primary" {
	ixfr-from-differences yes;
	request-ixfr yes;
	zone "test" IN {
		type primary;
		file "mytest.db";
		max-ixfr-ratio 75%;
	};
	zone "sub.test" IN {
		type primary;
		file "subtest.db";
	};
	zone "large" IN {
		type primary;
		file "large.db";
	};
};

options {
	query-source address 10.53.0.5;
	notify-source 10.53.0.5;
	transfer-source 10.53.0.5;
	port @PORT@;
	directory ".";
	pid-file "named.pid";
	listen-on { 10.53.0.5; };
	listen-on-v6 { none; };
	recursion yes;
	dnssec-validation no;
	notify yes;
	clients-per-query 5;
	max-clients-per-query 10;
};


server 10.53.0.4 {
	edns no;
};

{% include "_common/controls.conf.j2" %}

zone "." {
	type hint;
	file "root.hint";
};

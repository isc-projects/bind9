options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	port @PORT@;
	directory ".";
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	recursion yes;
	dnssec-validation no;
	notify yes;
	qname-minimization disabled;
	zone-statistics yes;
};

{% if FEATURE_LIBXML2 == "1" or FEATURE_JSON_C == "1" %}
statistics-channels {
	inet 10.53.0.3 port @EXTRAPORT1@ allow { any; };
};
{% endif %}

{% include "_common/controls.conf.j2" %}

zone "." {
	type hint;
	file "root.hint";
};

zone "example" {
	type primary;
	allow-update { any; };
	file "internal.db";
};

zone "a-secondary" {
	type secondary;
	file "sec.bk";
	primaries { 10.53.0.1; };
};

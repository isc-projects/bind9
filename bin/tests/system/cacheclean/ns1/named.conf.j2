options {
	query-source address 10.53.0.1;
	notify-source 10.53.0.1;
	transfer-source 10.53.0.1;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.1; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	dnssec-validation no;
	notify yes;
	check-integrity no;
	minimal-responses no;
};

{% include "_common/controls.conf.j2" %}

zone "." {
	type primary;
	file "example.db";
};

zone "bar.com" {
	type primary;
	file "bar.com.db";
};

zone "flushtest.example" {
	type primary;
	file "flushtest.db";
};

zone "expire-test" {
	type primary;
	file "expire-test.db";
};

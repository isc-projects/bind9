options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	port @PORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	dnssec-validation no;
	notify yes;
	check-integrity no;
	minimal-responses no;
};

{% include "_common/controls.conf.j2" %}

zone "foo.bar.com" {
	type primary;
	file "foo.bar.com.db";
};

options {
	query-source address 10.53.0.3;
	notify-source 10.53.0.3;
	transfer-source 10.53.0.3;
	port @PORT@;
	tls-port @TLSPORT@;
	pid-file "named.pid";
	listen-on { 10.53.0.3; };
	listen-on tls ephemeral { 10.53.0.3; };
	listen-on-v6 { none; };
	allow-transfer { any; };
	recursion no;
	dnssec-validation no;
	notify yes;
	update-quota 1;
};

{% include "_common/controls.conf.j2" %}

zone "example" {
	type secondary;
	file "example.bk";
	allow-update-forwarding { any; };
	primaries { 10.53.0.1; };
};
